Q3. Build a Docker image for the application
================================================================================

STEP 1: Install Docker
-----------------------
sudo apt install docker.io -y
sudo systemctl start docker
sudo systemctl enable docker
sudo usermod -aG docker $USER   # logout and login after this

STEP 2: Create app.py (Hello World Flask app)
----------------------------------------------
cat > app.py << 'EOF'
from flask import Flask
app = Flask(__name__)

@app.route('/')
def hello():
    return "<h1>Hello World from Docker!</h1>"

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
EOF

STEP 3: Create requirements.txt
---------------------------------
echo "flask" > requirements.txt

STEP 4: Create Dockerfile
--------------------------
cat > Dockerfile << 'EOF'
FROM python:3.9-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install -r requirements.txt
COPY . .
EXPOSE 5000
CMD ["python", "app.py"]
EOF

STEP 5: Build the Docker image
--------------------------------
docker build -t hello-world-app .

STEP 6: Verify the image was created
--------------------------------------
docker images


